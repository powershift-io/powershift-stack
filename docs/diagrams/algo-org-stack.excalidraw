    {"type":"text","id":"layer5b","x":106,"y":350,"width":840,"height":38,"text":"Primer · Constitution · Profiles · Roles/Circles/Policies · Nestr governance loop\nThis is the ruleset that defines authority, structure, and change","fontSize":16,"fontFamily":2,"strokeColor":"#495057"},

    {"type":"rectangle","id":"layer4","x":82,"y":425,"width":886,"height":100,"strokeColor":"#2f9e44","backgroundColor":"#d3f9d8","fillStyle":"solid","strokeWidth":2,"roughness":0},
    {"type":"text","id":"layer4a","x":105,"y":439,"width":330,"height":24,"text":"4. Legal Adoption Layer","fontSize":22,"fontFamily":2,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"layer4b","x":106,"y":471,"width":844,"height":38,"text":"Operating Agreement templates · Ratification docs · skinny constitutions by org profile\nThis is how the governance kernel becomes adoptable in real organizations","fontSize":16,"fontFamily":2,"strokeColor":"#495057"},

