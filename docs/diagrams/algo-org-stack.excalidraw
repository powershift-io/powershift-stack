    {"type":"text","id":"usesTitle","x":1052,"y":174,"width":250,"height":22,"text":"Why this matters commercially","fontSize":20,"fontFamily":2,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"usesBody","x":1054,"y":214,"width":320,"height":220,"text":"Gary gets a legible\narchitecture surface.\n\nJonah gets a pitchable story\nwith a real adoption path.\n\nOrchestrators can see where\ngovernance ends and runtime begins.\n\nThe repo becomes a trust surface,\nnot just a document dump.","fontSize":16,"fontFamily":2,"strokeColor":"#495057"},

