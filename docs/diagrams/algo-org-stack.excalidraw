    {"type":"text","id":"layer6b","x":106,"y":234,"width":820,"height":36,"text":"Orchestrators · Sovereign Minds · delegated agents · role-fillers\nAuthority lives in roles and relationships, not in a manager box","fontSize":16,"fontFamily":2,"strokeColor":"#495057"},

